DATABASE_URL=postgres://blog:blog_secret@localhost:5466/softwareblog
SERVER_HOST=0.0.0.0
SERVER_PORT=3000

# Generate with: cargo run --bin gen-hash -- "your-password"
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=19456,t=2,p=1$...

# Any random string, key is derived via HKDF — longer is better
# Generate with: openssl rand -hex 32
COOKIE_SECRET=change-this-to-any-random-string-in-production

# Plaintext password — only used by `cargo run --bin seed` to generate the hash
ADMIN_PASSWORD=changeme

RUST_LOG=info,softwareblog=debug
